{
  "name": "unsplash-vue",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:report": "vite build && node scripts/bundle-report.mjs",
    "preview": "vite preview",
    "lint": "eslint src --ext .vue,.js",
    "start": "node server.js",
    "api": "PORT=3000 node server.js",
    "heroku-postbuild": "npm install --only=dev --no-shrinkwrap && npm run build"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "axios-extensions": "^3.1.7",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "serve-static": "^1.14.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "vite": "^6.0.7",
    "vue-eslint-parser": "^9.4.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "browser": true,
      "es2022": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parser": "vue-eslint-parser",
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "vue/multi-word-component-names": "off"
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
